# API Gateway Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Downstream microservice base URLs (required for proxying)
# In Docker Compose, these should be service DNS names.
PATIENT_SERVICE_URL=http://patient-service:3001
DOCTOR_SERVICE_URL=http://doctor-service:3002
APPOINTMENT_SERVICE_URL=http://appointment-service:3003
NOTIFICATION_SERVICE_URL=http://notification-service:3004
PAYMENT_SERVICE_URL=http://payment-service:3005
ADMIN_SERVICE_URL=http://admin-service:3006
TELEMEDICINE_SERVICE_URL=http://telemedicine-service:3007
AUTH_SERVICE_URL=http://auth-service:3008
SYMPTOM_SERVICE_URL=http://ai-symptom-checker:3009
